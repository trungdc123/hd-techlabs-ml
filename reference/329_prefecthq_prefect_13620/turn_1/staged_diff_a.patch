+"""Tests for static (AST-based) entrypoint extraction utilities."""
+
+import textwrap
+from pathlib import Path
+
+import pytest
+
+from prefect.utilities.callables import (
+    _entrypoint_flow_description,
+    _entrypoint_flow_name,
+    _load_safe_namespace,
+    _read_flow_decorator_kwargs,
+    parameter_schema_from_entrypoint,
+)
