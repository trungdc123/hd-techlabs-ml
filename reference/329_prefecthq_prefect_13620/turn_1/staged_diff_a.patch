+def parameter_schema_from_entrypoint(entrypoint: str) -> ParameterSchema:
+    """Generate a parameter schema from an entrypoint string without importing the module."""
+    source_path, func_name = _resolve_source_path(entrypoint)
+    source_code = source_path.read_text()
+
+    tree = ast.parse(source_code)
+    func_def = None
+    for node in ast.walk(tree):
+        if isinstance(node, ast.FunctionDef) and node.name == func_name:
+            func_def = node
+            break
+
+    if func_def is None:
+        raise ValueError(f"Function {func_name!r} not found in {source_path!r}.")
+
+    namespace = _build_safe_namespace(source_code)
+    signature = _signature_from_ast(func_def, namespace)
+    docstring = _get_docstring_from_ast(func_def)
+    docstrings = parameter_docstrings(docstring)
+
+    return _generate_parameter_schema(signature, docstrings)
+
+
+def _read_flow_decorator_kwargs(
+    source_code: str, func_name: str
+) -> Optional[Dict[str, Any]]:
+    """Parse *source_code* as an AST and return the keyword arguments of the
+    ``@flow(...)`` decorator applied to *func_name*.
+
+    Returns an empty dict when the decorator is bare (``@flow`` without a call).
+    Returns ``None`` when the function is not found.
+    """
+    tree = ast.parse(source_code)
+    for node in ast.walk(tree):
+        if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
+            if node.name != func_name:
+                continue
+            kwargs = _find_flow_decorator_kwargs(node)
+            if kwargs is not None:
+                # Convert AST nodes to plain values where possible
+                result: Dict[str, Any] = {}
+                for k, v in kwargs.items():
+                    if isinstance(v, ast.Constant):
+                        result[k] = v.value
+                    else:
+                        result[k] = v
+                return result
+            # Function found but no @flow decorator
+            return {}
+    return None
+
+
+def _entrypoint_flow_name(entrypoint: str) -> str:
+    """Return the flow name for an entrypoint without importing the module."""
+    source_path, func_name = _resolve_source_path(entrypoint)
+    source_code = source_path.read_text()
+    return _read_flow_decorator_kwargs_from_source(source_code, func_name, "name")
+
+
+def _entrypoint_flow_description(entrypoint: str) -> Optional[str]:
+    """Return the flow description for an entrypoint without importing the module."""
+    source_path, func_name = _resolve_source_path(entrypoint)
+    source_code = source_path.read_text()
+    try:
+        return _read_flow_decorator_kwargs_from_source(
+            source_code, func_name, "description"
+        )
+    except ValueError:
+        return None
+
+
