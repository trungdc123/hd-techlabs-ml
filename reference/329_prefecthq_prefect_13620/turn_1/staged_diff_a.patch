+def _find_flow_decorator_kwargs(
+    func_def: ast.FunctionDef,
+) -> Optional[Dict[str, ast.expr]]:
+    """Find the @flow decorator on a function def and return its keyword arguments.
+
+    Returns None if no @flow decorator is found.
+    Returns an empty dict for a bare @flow decorator (no call).
+    """
+    for decorator in func_def.decorator_list:
+        if isinstance(decorator, ast.Call):
+            func = decorator.func
+            if (isinstance(func, ast.Name) and func.id == "flow") or (
+                isinstance(func, ast.Attribute) and func.attr == "flow"
+            ):
+                return {kw.arg: kw.value for kw in decorator.keywords if kw.arg}
+        elif isinstance(decorator, ast.Name) and decorator.id == "flow":
+            return {}
+        elif isinstance(decorator, ast.Attribute) and decorator.attr == "flow":
+            return {}
+    return None
+
+
+def _read_flow_decorator_kwargs_from_source(
+    source_code: str, func_name: str, keyword: str
+) -> Optional[str]:
+    """Extract a keyword argument value from a @flow decorator without executing the module.
+
+    Returns the string value of the keyword if found, otherwise falls back to:
+    - For 'name': function name with underscores replaced by hyphens
+    - For other keywords: None
+
+    Raises ValueError if the function is not found in the source.
+    """
+    tree = ast.parse(source_code)
+
+    for node in ast.walk(tree):
+        if isinstance(node, ast.FunctionDef) and node.name == func_name:
+            kwargs = _find_flow_decorator_kwargs(node)
+            if kwargs is None:
+                # Function found but no @flow decorator — treat as bare
+                kwargs = {}
+
+            if keyword in kwargs:
+                value_node = kwargs[keyword]
+                if isinstance(value_node, ast.Constant) and isinstance(
+                    value_node.value, str
+                ):
+                    return value_node.value
+
+            # Fallback
+            if keyword == "name":
+                return func_name.replace("_", "-")
+            return None
+
+    raise ValueError(
+        f"Function {func_name!r} not found in source."
+    )
+
+
+def _build_safe_namespace(source_code: str) -> Dict[str, Any]:
+    """Build a best-effort namespace from source code by executing import
+    statements and class/function definitions, swallowing any errors."""
+    tree = ast.parse(source_code)
+    namespace: Dict[str, Any] = {}
+
+    for node in tree.body:
+        if isinstance(node, (ast.Import, ast.ImportFrom)):
+            try:
+                code = compile(ast.Module(body=[node], type_ignores=[]), "<string>", "exec")
+                exec(code, namespace)
+            except Exception:
+                pass
+        elif isinstance(node, (ast.ClassDef, ast.FunctionDef, ast.AsyncFunctionDef)):
+            try:
+                code = compile(ast.Module(body=[node], type_ignores=[]), "<string>", "exec")
+                exec(code, namespace)
+            except Exception:
+                pass
+
+    return namespace
+
+
