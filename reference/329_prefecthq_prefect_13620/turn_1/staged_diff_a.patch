+class TestLoadSafeNamespace:
+    def test_successful_imports(self):
+        source = textwrap.dedent("""\
+            import os
+            import datetime
+            from typing import List
+        """)
+        ns = _load_safe_namespace(source)
+        assert "os" in ns
+        assert "datetime" in ns
+        assert "List" in ns
+
+    def test_failed_imports_swallowed(self):
+        source = textwrap.dedent("""\
+            import os
+            from nonexistent_package_xyz import Foo
+            import datetime
+        """)
+        ns = _load_safe_namespace(source)
+        assert "os" in ns
+        assert "datetime" in ns
+        assert "Foo" not in ns
+
+    def test_failed_class_definition_swallowed(self):
+        source = textwrap.dedent("""\
+            import os
+            from nonexistent_package_xyz import BaseClass
+
+            class MyClass(BaseClass):
+                pass
+
+            class GoodClass:
+                pass
+        """)
+        ns = _load_safe_namespace(source)
+        assert "os" in ns
+        assert "MyClass" not in ns
+        assert "GoodClass" in ns
