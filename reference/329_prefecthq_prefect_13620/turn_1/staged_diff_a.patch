+class TestReadFlowDecoratorKwargs:
+    def test_explicit_name(self):
+        source = textwrap.dedent("""\
+            from prefect import flow
+
+            @flow(name="my-custom-name")
+            def my_func():
+                pass
+        """)
+        kwargs = _read_flow_decorator_kwargs(source, "my_func")
+        assert kwargs["name"] == "my-custom-name"
+
+    def test_implicit_name_fallback_bare_decorator(self):
+        source = textwrap.dedent("""\
+            from prefect import flow
+
+            @flow
+            def my_func():
+                pass
+        """)
+        kwargs = _read_flow_decorator_kwargs(source, "my_func")
+        assert kwargs == {}
+        # When kwargs is empty, the caller should fall back to func name
+        assert kwargs.get("name", "my_func".replace("_", "-")) == "my-func"
+
+    def test_explicit_description(self):
+        source = textwrap.dedent("""\
+            from prefect import flow
+
+            @flow(description="A cool flow")
+            def my_func():
+                pass
+        """)
+        kwargs = _read_flow_decorator_kwargs(source, "my_func")
+        assert kwargs["description"] == "A cool flow"
+
+    def test_missing_description(self):
+        source = textwrap.dedent("""\
+            from prefect import flow
+
+            @flow(name="test")
+            def my_func():
+                pass
+        """)
+        kwargs = _read_flow_decorator_kwargs(source, "my_func")
+        assert "description" not in kwargs
+
+    def test_missing_function_returns_none(self):
+        source = textwrap.dedent("""\
+            from prefect import flow
+
+            @flow
+            def other_func():
+                pass
+        """)
+        result = _read_flow_decorator_kwargs(source, "nonexistent")
+        assert result is None
+
+    def test_prefect_dot_flow_decorator(self):
+        source = textwrap.dedent("""\
+            import prefect
+
+            @prefect.flow(name="dotted")
+            def my_func():
+                pass
+        """)
+        kwargs = _read_flow_decorator_kwargs(source, "my_func")
+        assert kwargs["name"] == "dotted"
+
