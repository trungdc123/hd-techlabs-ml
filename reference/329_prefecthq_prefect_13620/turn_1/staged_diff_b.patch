+
+class TestLoadSafeNamespace:
+    def test_successful_imports(self):
+        source = textwrap.dedent("""\
+            import datetime
+            from enum import Enum
+        """)
+        ns = callables._load_safe_namespace(source)
+        import datetime
+        from enum import Enum
+
+        assert ns["datetime"] is datetime
+        assert ns["Enum"] is Enum
+
+    def test_failed_imports_are_swallowed(self):
+        source = textwrap.dedent("""\
+            import nonexistent_package_abc
+            import datetime
+        """)
+        ns = callables._load_safe_namespace(source)
+        import datetime
+
+        assert "nonexistent_package_abc" not in ns
+        assert ns["datetime"] is datetime
+
+    def test_failed_class_definitions_are_swallowed(self):
+        source = textwrap.dedent("""\
+            import nonexistent_base_xyz
+
+            class Foo(nonexistent_base_xyz.Bar):
+                pass
+
+            class Good:
+                x: int = 1
+        """)
+        ns = callables._load_safe_namespace(source)
+        assert "Foo" not in ns
+        assert "Good" in ns
