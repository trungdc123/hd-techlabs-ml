+        schema = callables.parameter_schema_from_entrypoint(
+            f"{tmp_path / 'flows.py'}:my_flow"
+        )
+        assert schema.dict()["properties"]["x"]["description"] == "the value of x"
+
+    def test_missing_third_party_import_does_not_fail(self, tmp_path):
+        source = textwrap.dedent("""\
+            from prefect import flow
+            import nonexistent_package_xyz
+
+            @flow
+            def my_flow(x: int = 42):
+                pass
+        """)
+        (tmp_path / "flows.py").write_text(source)
+        schema = callables.parameter_schema_from_entrypoint(
+            f"{tmp_path / 'flows.py'}:my_flow"
