+class TestReadFlowDecoratorKwargs:
+    def test_explicit_name(self):
+        source = textwrap.dedent("""\
+            from prefect import flow
+
+            @flow(name="my-custom-name")
+            def my_flow():
+                pass
+        """)
+        result = callables._read_flow_decorator_kwargs(source, "my_flow")
+        assert result["name"] == "my-custom-name"
+
+    def test_implicit_name_fallback(self):
+        source = textwrap.dedent("""\
+            from prefect import flow
+
+            @flow
+            def my_flow():
+                pass
+        """)
+        result = callables._read_flow_decorator_kwargs(source, "my_flow")
+        # Bare @flow returns empty dict, so name falls back to func name
+        assert result == {}
+        assert result.get("name", "my_flow".replace("_", "-")) == "my-flow"
+
+    def test_implicit_name_fallback_decorator_with_no_name_kwarg(self):
+        source = textwrap.dedent("""\
+            from prefect import flow
+
+            @flow(retries=3)
+            def my_flow():
+                pass
+        """)
+        result = callables._read_flow_decorator_kwargs(source, "my_flow")
+        # No name kwarg, falls back to func name convention
+        assert "name" not in result
+        assert result.get("name", "my_flow".replace("_", "-")) == "my-flow"
+
+    def test_explicit_description(self):
+        source = textwrap.dedent("""\
+            from prefect import flow
+
+            @flow(description="A very important flow")
+            def my_flow():
+                pass
+        """)
+        result = callables._read_flow_decorator_kwargs(source, "my_flow")
+        assert result["description"] == "A very important flow"
+
